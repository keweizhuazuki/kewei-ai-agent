{
  "mcpServers": {
    "amap-maps": {
      "command": "npx",
      "args": [
        "-y",
        "@amap/amap-maps-mcp-server"
      ],
      "env": {
        "AMAP_MAPS_API_KEY": "REPLACE_WITH_YOUR_AMAP_MAPS_API_KEY"
      }
    },
    "kewei-image-search-mcp-server": {
      "command": "java",
      "args": [
        "-Dspring.ai.mcp.server.stdio=true",
        "-Dspring.main.web-application-type=none",
        "-Dlogging.pattern.console=",
        "-jar",
        "kewei-image-search-mcp-server/target/kewei-image-search-mcp-server-0.0.1-SNAPSHOT.jar"
      ]
    },
    "kewei-image-generation-mcp-server": {
      "command": "java",
      "args": [
        "-Dspring.ai.mcp.server.stdio=true",
        "-Dspring.main.web-application-type=none",
        "-Dlogging.pattern.console=",
        "-jar",
        "kewei-image-generation-mcp-server/target/kewei-image-generation-mcp-server-0.0.1-SNAPSHOT.jar"
      ]
    }
  }
}
